{
  "name": "serve-static-git",
  "description": "Express middleware to serve static files directly from a `.git` repository.",
  "version": "0.3.0",
  "author": "@kawanet",
  "bugs": {
    "url": "https://github.com/kawanet/serve-static-git/issues"
  },
  "dependencies": {
    "git-cat-file": "^0.4.1",
    "mime": "^3.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-sucrase": "^5.1.0",
    "@types/express4": "npm:@types/express@^4",
    "@types/express5": "npm:@types/express@^5",
    "@types/finalhandler": "^1.2.4",
    "@types/mime": "^3.0.4",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.2",
    "express-intercept": "^1.2.0",
    "express4": "npm:express@^4",
    "express5": "npm:express@^5",
    "finalhandler": "^2.0.0",
    "qs-lite": "^1.0.0",
    "rollup": "^4.60.2",
    "supertest": "^7.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "require": "./dist/serve-static-git.cjs",
      "import": {
        "types": "./types/serve-static-git.d.ts",
        "default": "./dist/serve-static-git.mjs"
      }
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/serve-static-git.cjs",
    "dist/serve-static-git.mjs",
    "lib/*.ts",
    "types/*.d.ts"
  ],
  "homepage": "https://github.com/kawanet/serve-static-git#readme",
  "keywords": [
    "Express",
    "git",
    "repository"
  ],
  "license": "MIT",
  "main": "./dist/serve-static-git.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kawanet/serve-static-git.git"
  },
  "scripts": {
    "build": "make -C builder",
    "fixpack": "fixpack",
    "prepack": "make -C builder test",
    "prepare": "make -C builder clean all",
    "test": "make -C builder test"
  },
  "sideEffects": false,
  "type": "module",
  "types": "types/serve-static-git.d.ts"
}
